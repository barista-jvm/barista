#!/usr/bin/env bash
# Summary: Install a Java version (brew a new JDK)
# Usage: barista brew [-f|--force] <dist>@<version>
#        barista brew -l|--list
#        barista brew --version
#
# Downloads and installs a JDK from a configured distribution.
# The installed version lives at $BARISTA_ROOT/versions/<version>/.
# Use 'barista brew --list' to see available dist@version values.
#
# Flags:
#   -l / --list    List available Java versions from all distributions
#   -f / --force   Install even if the version is already present
#   --version      Show the version of barista-brew
#
# Built-in distributions: adoptium, corretto, zulu, microsoft, openjdk
# Custom distributions:   place a <name>.sh script in
#                         $BARISTA_ROOT/distributions/
#
# Aliases:
#   @lts     Resolves to the current LTS release for the distribution
#   @latest  Resolves to the latest available release for the distribution
#
# Examples:
#   barista brew --list
#   barista brew adoptium@21
#   barista brew adoptium@lts
#   barista brew adoptium@latest
#   barista brew corretto@21
#   barista brew openjdk@17
#   barista brew adoptium@21 --force

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"
export BARISTA_DIR="${BARISTA_DIR:-${_BARISTA_INSTALL_PREFIX:-$(cd "$(dirname "$0")/.." && pwd)}}"

BREW_VERSION="$(cat "${BARISTA_DIR}/version.txt" 2>/dev/null | tr -d '[:space:]')"
BREW_VERSION="${BREW_VERSION:-unknown}"

list_only=""
force=""
version=""
distribution="adoptium"

while [ $# -gt 0 ]; do
  case "$1" in
  -l | --list    ) list_only=1; shift ;;
  -f | --force   ) force=1; shift ;;
  --version      ) echo "barista-brew $BREW_VERSION"; exit 0 ;;
  *              ) version="$1"; shift ;;
  esac
done

# Parse "dist@version" format, e.g. "openjdk@23" or "corretto@21.0.3"
case "$version" in
  *@*)
    distribution="${version%%@*}"
    version="${version##*@}"
    ;;
esac

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

require_curl() {
  if ! command -v curl >/dev/null 2>&1; then
    echo "barista: curl is required but not found in PATH" >&2
    exit 1
  fi
}

# Resolve 'lts' or 'latest' alias to a major version number.
# Calls dist_resolve_alias() if the distribution defines it; otherwise falls
# back to a numeric sort of dist_list() for @latest. @lts without a
# dist_resolve_alias() implementation exits with an error.
resolve_alias() {
  local alias="$1" resolved
  if command -v dist_resolve_alias >/dev/null 2>&1; then
    resolved="$(dist_resolve_alias "$alias")"
    if [ -z "$resolved" ]; then
      echo "barista: @${alias} is not supported by distribution '${distribution}'" >&2
      exit 1
    fi
    printf '%s' "$resolved"
    return
  fi
  case "$alias" in
  latest )
    if command -v dist_list >/dev/null 2>&1; then
      resolved="$(dist_list 2>/dev/null | grep -E '^[0-9]' | sort -t. -k1,1n | tail -1)"
      if [ -z "$resolved" ]; then
        echo "barista: could not resolve @latest for distribution '${distribution}'" >&2
        exit 1
      fi
      printf '%s' "$resolved"
    else
      echo "barista: distribution '${distribution}' does not support @latest" >&2
      exit 1
    fi
    ;;
  lts )
    echo "barista: distribution '${distribution}' does not support @lts" >&2
    echo "        Add dist_resolve_alias() to the distribution script to enable it." >&2
    exit 1
    ;;
  esac
}

# Resolve a partial version string to the latest matching full version from
# dist_list(). Examples: "25" → "25.0.3", "21.0" → "21.0.11", "25.0.3" → "25.0.3"
# Falls back to the input unchanged if dist_list() is unavailable or has no match.
resolve_version() {
  local partial="$1" escaped resolved
  command -v dist_list >/dev/null 2>&1 || { printf '%s' "$partial"; return 0; }
  escaped="$(printf '%s' "$partial" | sed 's/\./\\./g')"
  resolved="$(dist_list 2>/dev/null | grep -E "^${escaped}(\.|$)" | head -1)"
  printf '%s' "${resolved:-$partial}"
}

detect_os() {
  case "$(uname -s)" in
  Darwin ) echo "mac" ;;
  Linux  ) echo "linux" ;;
  *      ) echo "linux" ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
  x86_64          ) echo "x64" ;;
  aarch64 | arm64 ) echo "aarch64" ;;
  *               ) echo "x64" ;;
  esac
}

# ---------------------------------------------------------------------------
# Load distribution script
# ---------------------------------------------------------------------------

load_distribution() {
  local name="$1"
  local dist_file=""
  local user_dir="${BARISTA_ROOT}/distributions"
  local builtin_dir="${BARISTA_DIR}/distributions"

  # User-defined overrides built-in
  for dir in "$user_dir" "$builtin_dir"; do
    if [ -f "${dir}/${name}.sh" ]; then
      dist_file="${dir}/${name}.sh"
      break
    fi
  done

  if [ -z "$dist_file" ]; then
    echo "barista: unknown distribution '${name}'" >&2
    echo "        Use 'barista brew --list' to see available distributions." >&2
    echo "        Add custom distributions to ${user_dir}/." >&2
    exit 1
  fi

  # shellcheck source=/dev/null
  . "$dist_file"

  if ! command -v dist_url >/dev/null 2>&1; then
    echo "barista: distribution '${name}' does not define dist_url()" >&2
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# List mode
# ---------------------------------------------------------------------------

list_one_distribution() {
  local name="$1"
  unset -f dist_url dist_list 2>/dev/null || true
  DIST_NAME=""
  load_distribution "$name"
  if command -v dist_list >/dev/null 2>&1; then
    dist_list | while IFS= read -r ver; do
      [ -n "$ver" ] && printf '%s@%s\n' "$name" "$ver"
    done
  fi
}

list_all_distributions() {
  local user_dir="${BARISTA_ROOT}/distributions"
  local builtin_dir="${BARISTA_DIR}/distributions"
  local all_names=""

  for dir in "$builtin_dir" "$user_dir"; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.sh; do
      [ -f "$f" ] || continue
      local name
      name="$(basename "$f" .sh)"
      case " $all_names " in
        *" $name "*) ;;
        *) all_names="${all_names:+$all_names }$name" ;;
      esac
    done
  done

  if [ -z "$all_names" ]; then
    echo "barista: no distributions found in ${builtin_dir} or ${user_dir}" >&2
    return 1
  fi

  for name in $all_names; do
    list_one_distribution "$name"
  done
}

if [ -n "$list_only" ]; then
  require_curl
  list_all_distributions
  exit 0
fi

# ---------------------------------------------------------------------------
# Install mode
# ---------------------------------------------------------------------------

if [ -z "$version" ]; then
  echo "Usage: barista brew <dist>@<version>" >&2
  echo "       barista brew --list" >&2
  exit 1
fi

require_curl
load_distribution "$distribution"

# Resolve lts/latest aliases to a concrete major version before partial resolution
case "$version" in
lts | latest ) version="$(resolve_alias "$version")" ;;
esac

# Resolve partial input to the latest matching full version, e.g. "25" → "25.0.3"
version="$(resolve_version "$version")"

os="$(detect_os)"
arch="$(detect_arch)"
versions_dir="${BARISTA_ROOT}/versions"
install_dir="${versions_dir}/${distribution}@${version}"

if [ -d "$install_dir" ] && [ -z "$force" ]; then
  echo "barista: ${distribution}@${version} is already brewed at ${install_dir}" >&2
  echo "        Use '--force' to reinstall." >&2
  exit 1
fi

# Strip to feature version (major number) for the API / URL
feature_version="${version%%.*}"
feature_version="${feature_version%%+*}"

download_url="$(dist_url "$feature_version" "$os" "$arch")"

if [ -z "$download_url" ]; then
  echo "barista: distribution '${distribution}' returned no URL for Java ${version} on ${os}/${arch}" >&2
  exit 1
fi

echo "==> Brewing Java ${version} (feature release ${feature_version})"
echo "    Platform     : ${os}/${arch}"
echo "    Distribution : ${DIST_NAME:-$distribution}"
echo "    Source       : ${download_url}"
echo

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

archive="${tmpdir}/jdk.tar.gz"

echo "==> Downloading..."
if ! curl -L --progress-bar --fail --retry 3 --retry-delay 2 -o "$archive" "$download_url"; then
  echo "barista: download failed" >&2
  echo "        URL: ${download_url}" >&2
  exit 1
fi

if command -v dist_checksum_url >/dev/null 2>&1; then
  checksum_url="$(dist_checksum_url "$feature_version" "$os" "$arch")"
  if [ -n "$checksum_url" ]; then
    echo "==> Verifying SHA256 checksum..."
    expected_hash="$(curl -sf "$checksum_url" | grep -oE '[0-9a-f]{64}' | head -1)"
    if [ -z "$expected_hash" ]; then
      echo "barista: could not fetch checksum from ${checksum_url}" >&2
      exit 1
    fi
    if command -v sha256sum >/dev/null 2>&1; then
      actual_hash="$(sha256sum "$archive" | cut -d' ' -f1)"
    elif command -v shasum >/dev/null 2>&1; then
      actual_hash="$(shasum -a 256 "$archive" | cut -d' ' -f1)"
    else
      echo "barista: warning: no sha256 tool found; skipping checksum verification" >&2
      actual_hash=""
    fi
    if [ -n "$actual_hash" ] && [ "$actual_hash" != "$expected_hash" ]; then
      echo "barista: SHA256 checksum mismatch!" >&2
      echo "        expected: ${expected_hash}" >&2
      echo "        got:      ${actual_hash}" >&2
      exit 1
    fi
    echo "    Checksum OK"
  fi
fi

echo
echo "==> Installing to ${install_dir} ..."

mkdir -p "$install_dir"
tar -xzf "$archive" -C "$install_dir" --strip-components=1

# JDK archives vary in how many levels deep bin/java is buried.
# Adoptium macOS:  install_dir/Contents/Home/bin/java        (1 extra level)
# OpenJDK macOS:   install_dir/jdk-X.Y.Z.jdk/Contents/Home/bin/java (2 extra)
# Linux tarballs:  install_dir/bin/java                      (no nesting)
# Find bin/java wherever it landed and promote its parent to install_dir.
if [ ! -f "${install_dir}/bin/java" ]; then
  java_bin="$(find "$install_dir" -maxdepth 5 -name java -type f | head -1)"
  if [ -n "$java_bin" ]; then
    tmp_home="${tmpdir}/jdk-home"
    mv "$(dirname "$(dirname "$java_bin")")" "$tmp_home"
    rm -rf "$install_dir"
    mv "$tmp_home" "$install_dir"
  fi
fi

if [ ! -x "${install_dir}/bin/java" ]; then
  echo "barista: installation looks incomplete — ${install_dir}/bin/java not found" >&2
  rm -rf "$install_dir"
  exit 1
fi

# Record which distribution was used
printf '%s\n' "$distribution" > "${install_dir}/.barista-dist"

echo "==> Restocking shims..."
barista-restock 2>/dev/null || true

echo
echo "${distribution}@${version} brewed successfully."
echo
echo "Next steps:"
echo "  barista house ${distribution}@${version}   # set as the global default"
echo "  barista table ${distribution}@${version}   # set for the current directory"
