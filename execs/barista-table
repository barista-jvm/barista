#!/usr/bin/env bash
# Summary: Set or show the local Java version for this directory (this table)
# Usage: barista table [-f|--force] [<version>...]
#        barista table --unset
#
# Writes the version to .java-version in the current directory.
# Barista walks up the directory tree to find this file.
#
# Flags:
#   -f / --force  Skip verifying that the version is installed
#   --unset       Remove the local .java-version file
#
# Examples:
#   barista table           # show local version
#   barista table 21        # set local version
#   barista table --unset   # remove local .java-version

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"

force=""
unset_version=""
versions=()

for arg in "$@"; do
  case "$arg" in
  -f | --force ) force=1 ;;
  --unset      ) unset_version=1 ;;
  *            ) versions+=("$arg") ;;
  esac
done

local_version_file="${PWD}/.java-version"

if [ -n "$unset_version" ]; then
  if [ -e "$local_version_file" ]; then
    rm "$local_version_file"
    echo "barista: removed local version file ($local_version_file)"
  else
    echo "barista: no local version file in current directory" >&2
    exit 1
  fi
  exit 0
fi

if [ ${#versions[@]} -eq 0 ]; then
  if [ -f "$local_version_file" ]; then
    barista-version-file-read "$local_version_file"
  else
    found_file="$(barista-version-file 2>/dev/null || true)"
    if [ -n "$found_file" ] && [ -f "$found_file" ]; then
      v="$(barista-version-file-read "$found_file")"
      echo "${v} (set by ${found_file})"
    else
      echo "barista: no local version set" >&2
      exit 1
    fi
  fi
  exit 0
fi

if [ -z "$force" ]; then
  for version in "${versions[@]}"; do
    if [ "$version" != "system" ]; then
      version_dir="${BARISTA_ROOT}/versions/${version}"
      if [ ! -d "$version_dir" ]; then
        echo "barista: version '${version}' not installed" >&2
        echo "        Run 'barista brew ${version}' to install it." >&2
        exit 1
      fi
    fi
  done
fi

barista-version-file-write "$local_version_file" "${versions[*]}"
echo "barista: set local Java version to '${versions[*]}' ($local_version_file)"
