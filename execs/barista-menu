#!/usr/bin/env bash
# Summary: List all Java versions available to barista
# Usage: barista menu [--bare]
#
# Lists installed Java versions under $BARISTA_ROOT/versions/.
# The currently active version is marked with an asterisk (*).
#
# Flags:
#   --bare  Print only version names, one per line

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"

bare=""

for arg in "$@"; do
  case "$arg" in
  --bare ) bare=1 ;;
  esac
done

versions_dir="${BARISTA_ROOT}/versions"

if [ ! -d "$versions_dir" ]; then
  [ -z "$bare" ] && echo "  (no Java versions installed)"
  exit 0
fi

# Resolve the active version and its origin from barista-serving so that
# all precedence layers (BARISTA_VERSION, .java-version, global file) are
# correctly reflected in the active-version marker line.
current_serving="$(barista-serving 2>/dev/null || true)"
current_version="${current_serving%% *}"

shopt -s nullglob
found=0
for version_dir in "${versions_dir}"/*/; do
  version="${version_dir%/}"
  version="${version##*/}"
  found=1
  if [ -n "$bare" ]; then
    echo "$version"
  elif [ "$version" = "$current_version" ]; then
    echo "* ${current_serving}"
  else
    echo "  $version"
  fi
done

if [ "$found" -eq 0 ] && [ -z "$bare" ]; then
  echo "  (no Java versions installed)"
fi
