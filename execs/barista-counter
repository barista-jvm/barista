#!/usr/bin/env bash
# Summary: Display the install prefix (counter location) for Java versions
# Usage: barista counter [<version>...]
#
# Prints the full path to the installation directory for the given version(s).
# Defaults to the currently active version.
#
# Examples:
#   barista counter           # prefix of active version
#   barista counter 21        # prefix of Java 21

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"

if [ $# -eq 0 ]; then
  current="$(barista-serving --bare 2>/dev/null || echo "system")"
  set -- "$current"
fi

for version in "$@"; do
  if [ "$version" = "system" ]; then
    java_bin="$(command -v java 2>/dev/null || true)"
    if [ -z "$java_bin" ]; then
      echo "barista: system Java not found in PATH" >&2
      exit 1
    fi
    # Resolve symlinks then strip /bin/java
    real_java="$(readlink -f "$java_bin" 2>/dev/null \
               || greadlink -f "$java_bin" 2>/dev/null \
               || echo "$java_bin")"
    echo "${real_java%/bin/java}"
  else
    version_dir="${BARISTA_ROOT}/versions/${version}"
    if [ ! -d "$version_dir" ]; then
      echo "barista: version '${version}' not installed" >&2
      exit 1
    fi
    echo "$version_dir"
  fi
done
