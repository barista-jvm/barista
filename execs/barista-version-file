#!/usr/bin/env bash
# Summary: Detect the file that sets the current barista version
# Usage: barista version-file [<dir>]
#
# Walks up from <dir> (defaults to the current directory) looking for a
# .java-version file. Falls back to the global version file.

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"

search_dir="${1:-$PWD}"

while true; do
  if [ -f "${search_dir}/.java-version" ]; then
    echo "${search_dir}/.java-version"
    exit 0
  fi
  [ "$search_dir" = "/" ] && break
  search_dir="${search_dir%/*}"
  [ -z "$search_dir" ] && search_dir="/"
done

echo "${BARISTA_ROOT}/version"
