#!/usr/bin/env bash
# Summary: Set or show the shell-specific Java version for this session
# Usage: barista session <version>
#        barista session -         # restore previously set version
#        barista session --unset   # clear BARISTA_VERSION
#
# Overrides both local and global versions for the current shell session
# by exporting the BARISTA_VERSION environment variable.
#
# Note: 'barista session' must be wrapped in a shell function for the export
# to take effect in the calling shell. See 'barista setup'.
#
# Examples:
#   barista session 21        # use Java 21 in this shell
#   barista session --unset   # clear the override

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

export BARISTA_ROOT="${BARISTA_ROOT:-$HOME/.barista}"

shell="${BARISTA_SHELL:-bash}"
version="$1"

if [ -z "$version" ]; then
  if [ -n "$BARISTA_VERSION" ]; then
    echo "$BARISTA_VERSION"
  else
    echo "barista: BARISTA_VERSION is not set" >&2
    exit 1
  fi
  exit 0
fi

if [ "$version" = "--unset" ] || [ "$version" = "-" ]; then
  case "$shell" in
  fish ) echo "set -e BARISTA_VERSION" ;;
  *    ) echo "unset BARISTA_VERSION" ;;
  esac
  exit 0
fi

if [ "$version" != "system" ]; then
  version_dir="${BARISTA_ROOT}/versions/${version}"
  if [ ! -d "$version_dir" ]; then
    echo "barista: version '${version}' not installed" >&2
    echo "        Run 'barista brew ${version}' to install it." >&2
    exit 1
  fi
fi

case "$shell" in
fish ) echo "set -gx BARISTA_VERSION \"${version}\"" ;;
*    ) echo "export BARISTA_VERSION=\"${version}\"" ;;
esac
