#!/usr/bin/env bash
# Summary: List all available barista commands
# Usage: barista commands [--sh]
#
# Lists all commands, including shell-function variants when --sh is given.

set -e
[ -n "$BARISTA_DEBUG" ] && set -x

if [ -z "$BARISTA_DIR" ]; then
  BARISTA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

include_sh=""
for arg in "$@"; do
  case "$arg" in
  --sh ) include_sh=1 ;;
  esac
done

shopt -s nullglob
for cmd_file in "${BARISTA_DIR}/execs/barista-"*; do
  name="${cmd_file##*/barista-}"
  if [ -z "$include_sh" ]; then
    case "$name" in
    sh-* ) continue ;;
    esac
  fi
  echo "$name"
done | sort
