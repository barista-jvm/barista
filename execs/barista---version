#!/usr/bin/env bash
# Summary: Display the version of barista
# Usage: barista --version

set -e

BARISTA_DIR="${BARISTA_DIR:-${_BARISTA_INSTALL_PREFIX:-$(cd "$(dirname "$0")/.." && pwd)}}"
version="$(cat "${BARISTA_DIR}/version.txt" 2>/dev/null | tr -d '[:space:]')"
echo "barista ${version:-unknown}"
